{
    "name": "daniel-km/omeka-s-module-reference",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Add glossary pages and blocks with the alphabetical indexes of specified classes and properties.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "glossary",
        "indexing",
        "lexicon"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-Reference",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-Reference/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.1",
        "daniel-km/omeka-s-module-common": "*"
    },
    "autoload": {
        "psr-4": {
            "Reference\\": "src/"
        }
    },
    "autoload-dev": {
